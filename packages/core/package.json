{
  "name": "guideway",
  "version": "0.2.0",
  "description": "Product tours, coachmarks, and spotlight onboarding for React Native and Expo. Fabric-first, Reanimated-powered, hook-first.",
  "keywords": [
    "react-native",
    "expo",
    "onboarding",
    "product-tour",
    "coachmark",
    "spotlight",
    "walkthrough",
    "tooltip",
    "reanimated",
    "new-architecture"
  ],
  "license": "MIT",
  "author": "Claudiu Sararu",
  "homepage": "https://guideway.dev",
  "repository": { "type": "git", "url": "git+https://github.com/claudiusararu/guideway.git" },
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/commonjs/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": ["src", "lib", "!**/__tests__", "!**/*.test.*", "README.md"],
  "exports": {
    ".": {
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    }
  },
  "sideEffects": false,
  "scripts": {
    "prepare": "bob build",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-reanimated": ">=3",
    "react-native-svg": ">=14"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-react": "^7.25.0",
    "@babel/preset-typescript": "^7.25.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^19.0.0",
    "jest": "^29.7.0",
    "react": "19.0.0",
    "react-native": "0.81.0",
    "react-native-builder-bob": "^0.40.0",
    "react-native-reanimated": "^3.16.0",
    "react-native-svg": "^15.8.0",
    "typescript": "^5.6.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [["module", { "esm": true }], ["commonjs", { "esm": true }], "typescript"]
  }
}
